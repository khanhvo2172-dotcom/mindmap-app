# ---------------------------------------------------------------------------
# Copy this file to `.streamlit/secrets.toml` for LOCAL dev, OR paste the same
# content into Streamlit Cloud → Manage app → Settings → Secrets.
# Do NOT commit the real secrets.toml (it is git-ignored).
#
# Fill every value from your service-account JSON key file. The account must be
# shared (Viewer) on the Google Sheet.
# ---------------------------------------------------------------------------
[gcp_service_account]
type = "service_account"
project_id = "focused-outlook-465107-u9"
private_key_id = "YOUR_PRIVATE_KEY_ID"
private_key = """-----BEGIN PRIVATE KEY-----
YOUR
MULTILINE
PRIVATE_KEY
-----END PRIVATE KEY-----
"""
client_email = "google-drive-files-editor@focused-outlook-465107-u9.iam.gserviceaccount.com"
client_id = "YOUR_CLIENT_ID"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "YOUR_CERT_URL"
universe_domain = "googleapis.com"
